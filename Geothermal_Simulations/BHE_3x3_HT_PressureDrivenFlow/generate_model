    "# =========================================================\n",
    "# 2. Build VTU meshes\n",
    "#    - bulk mesh: model_mesh.vtu\n",
    "#    - heater submesh: heater_mesh.vtu\n",
    "# =========================================================\n",
    "def build_meshes():\n",
    "    print(\"1. Building bulk mesh and heater submesh...\")\n",
    "\n",
    "    x = make_coords(CFG[\"lx\"], CFG[\"nx\"])\n",
    "    y = make_coords(CFG[\"ly\"], CFG[\"ny\"])\n",
    "    z = np.linspace(-CFG[\"lz\"], 0.0, CFG[\"nz\"] + 1)\n",
    "\n",
    "    X, Y, Z = np.meshgrid(x, y, z, indexing=\"ij\")\n",
    "    points = np.column_stack([X.ravel(), Y.ravel(), Z.ravel()])\n",
    "\n",
    "    cx = cell_centers_1d(x)\n",
    "    cy = cell_centers_1d(y)\n",
    "    cz = cell_centers_1d(z)\n",
    "\n",
    "    bhe_ix, bhe_iy = build_heater_indices(cx, cy)\n",
    "\n",
    "    print(f\"   -> heater ix = {bhe_ix}\")\n",
    "    print(f\"   -> heater iy = {bhe_iy}\")\n",
    "\n",
    "    hexas = []\n",
    "    material_ids = []\n",
    "    heater_cell_ids = []\n",
    "    \n",
    "    cell_counter = 0\n",
    "    \n",
    "    for i in range(CFG[\"nx\"]):\n",
    "        for j in range(CFG[\"ny\"]):\n",
    "            for k in range(CFG[\"nz\"]):\n",
    "                n0 = node_id(i,   j,   k,   CFG[\"ny\"], CFG[\"nz\"])\n",
    "                n1 = node_id(i+1, j,   k,   CFG[\"ny\"], CFG[\"nz\"])\n",
    "                n2 = node_id(i+1, j+1, k,   CFG[\"ny\"], CFG[\"nz\"])\n",
    "                n3 = node_id(i,   j+1, k,   CFG[\"ny\"], CFG[\"nz\"])\n",
    "                n4 = node_id(i,   j,   k+1, CFG[\"ny\"], CFG[\"nz\"])\n",
    "                n5 = node_id(i+1, j,   k+1, CFG[\"ny\"], CFG[\"nz\"])\n",
    "                n6 = node_id(i+1, j+1, k+1, CFG[\"ny\"], CFG[\"nz\"])\n",
    "                n7 = node_id(i,   j+1, k+1, CFG[\"ny\"], CFG[\"nz\"])\n",
    "    \n",
    "                conn = [n0, n1, n2, n3, n4, n5, n6, n7]\n",
    "                hexas.append(conn)\n",
    "    \n",
    "                is_heater_xy = (i in bhe_ix) and (j in bhe_iy)\n",
    "                is_heater_z = (CFG[\"bhe_bottom\"] <= cz[k] <= CFG[\"bhe_top\"])\n",
    "    \n",
    "                if is_heater_xy and is_heater_z:\n",
    "                    material_ids.append(0)   # 注意：bulk mesh 一律使用 material 0\n",
    "                    heater_cell_ids.append(cell_counter)\n",
    "                else:\n",
    "                    material_ids.append(0)\n",
    "    \n",
    "                cell_counter += 1\n",
    "\n",
    "    hexas = np.asarray(hexas, dtype=np.int64)\n",
    "    material_ids = np.asarray(material_ids, dtype=np.int32)\n",
    "    heater_cell_ids = np.asarray(heater_cell_ids, dtype=np.int64)\n",
    "\n",
    "    # ---------- bulk mesh ----------\n",
    "    bulk_mesh = meshio.Mesh(\n",
    "        points=points,\n",
    "        cells=[(\"hexahedron\", hexas)],\n",
    "        cell_data={\n",
    "            \"MaterialIDs\": [material_ids],\n",
    "            \"bulk_element_ids\": [np.arange(len(hexas), dtype=np.uint64)]\n",
    "        },\n",
    "        point_data={\n",
    "            \"bulk_node_ids\": np.arange(points.shape[0], dtype=np.uint64)\n",
    "        }\n",
    "    )\n",
    "    bulk_mesh.write(BULK_MESH_FILE)\n",
    "\n",
    "    print(f\"   -> {BULK_MESH_FILE} written\")\n",
    "    print(f\"   -> total points        = {points.shape[0]}\")\n",
    "    print(f\"   -> total hexas         = {hexas.shape[0]}\")\n",
    "    print(f\"   -> heater bulk cells   = {heater_cell_ids.size}\")\n",
    "\n",
    "    # ---------- heater submesh ----------\n",
    "    # 只取 heater elements，並重新編號節點\n",
    "    heater_hexas_bulk = hexas[heater_cell_ids]\n",
    "    used_point_ids = np.unique(heater_hexas_bulk.ravel())\n",
    "\n",
    "    old_to_new = {old_id: new_id for new_id, old_id in enumerate(used_point_ids)}\n",
    "    heater_hexas_local = np.vectorize(old_to_new.get)(heater_hexas_bulk)\n",
    "\n",
    "    heater_points = points[used_point_ids]\n",
    "\n",
    "    heater_mesh = meshio.Mesh(\n",
    "        points=heater_points,\n",
    "        cells=[(\"hexahedron\", heater_hexas_local.astype(np.int64))],\n",
    "        cell_data={\n",
    "            \"bulk_element_ids\": [heater_cell_ids.astype(np.uint64)]\n",
    "        },\n",
    "        point_data={\n",
    "            \"bulk_node_ids\": used_point_ids.astype(np.uint64)\n",
    "        }\n",
    "    )\n",
    "    heater_mesh.write(HEATER_MESH_FILE)\n",
    "\n",
    "    print(f\"   -> {HEATER_MESH_FILE} written\")\n",
    "    print(f\"   -> heater points       = {heater_points.shape[0]}\")\n",
    "    print(f\"   -> heater hexas        = {heater_hexas_local.shape[0]}\")\n",
    "\n"
   ]
