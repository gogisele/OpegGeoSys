    "# =========================================================\n",
    "# 3. Build GML geometry\n",
    "# =========================================================\n",
    "def build_gml():\n",
    "    print(\"2. Building GML geometry...\")\n",
    "\n",
    "    x0, x1 = -CFG[\"lx\"]/2.0, CFG[\"lx\"]/2.0\n",
    "    y0, y1 = -CFG[\"ly\"]/2.0, CFG[\"ly\"]/2.0\n",
    "    z0, z1 = -CFG[\"lz\"], 0.0\n",
    "\n",
    "    gml = f\"\"\"<?xml version=\"1.0\" encoding=\"ISO-8859-1\"?>\n",
    "<OpenGeoSysGLI>\n",
    "    <name>geo</name>\n",
    "\n",
    "    <points>\n",
    "        <point id=\"0\" x=\"{x0}\" y=\"{y0}\" z=\"{z1}\"/>\n",
    "        <point id=\"1\" x=\"{x0}\" y=\"{y1}\" z=\"{z1}\"/>\n",
    "        <point id=\"2\" x=\"{x0}\" y=\"{y1}\" z=\"{z0}\"/>\n",
    "        <point id=\"3\" x=\"{x0}\" y=\"{y0}\" z=\"{z0}\"/>\n",
    "\n",
    "        <point id=\"4\" x=\"{x1}\" y=\"{y0}\" z=\"{z1}\"/>\n",
    "        <point id=\"5\" x=\"{x1}\" y=\"{y1}\" z=\"{z1}\"/>\n",
    "        <point id=\"6\" x=\"{x1}\" y=\"{y1}\" z=\"{z0}\"/>\n",
    "        <point id=\"7\" x=\"{x1}\" y=\"{y0}\" z=\"{z0}\"/>\n",
    "    </points>\n",
    "\n",
    "    <surfaces>\n",
    "        <surface id=\"0\" name=\"left_face\">\n",
    "            <element p1=\"0\" p2=\"1\" p3=\"2\"/>\n",
    "            <element p1=\"0\" p2=\"2\" p3=\"3\"/>\n",
    "        </surface>\n",
    "\n",
    "        <surface id=\"1\" name=\"right_face\">\n",
    "            <element p1=\"4\" p2=\"5\" p3=\"6\"/>\n",
    "            <element p1=\"4\" p2=\"6\" p3=\"7\"/>\n",
    "        </surface>\n",
    "\n",
    "        <surface id=\"2\" name=\"top_face\">\n",
    "            <element p1=\"0\" p2=\"1\" p3=\"5\"/>\n",
    "            <element p1=\"0\" p2=\"5\" p3=\"4\"/>\n",
    "        </surface>\n",
    "    </surfaces>\n",
    "</OpenGeoSysGLI>\n",
    "\"\"\"\n",
    "    with open(GML_FILE, \"w\", encoding=\"utf-8\") as f:\n",
    "        f.write(gml)\n",
    "\n",
    "    print(f\"   -> {GML_FILE} written\")\n"
   ]
