    "# =========================================================\n",
    "# 0. Configuration\n",
    "# =========================================================\n",
    "CFG = {\n",
    "    # Domain size\n",
    "    \"lx\": 100.0,\n",
    "    \"ly\": 100.0,\n",
    "    \"lz\": 40.0,\n",
    "\n",
    "    # Mesh resolution\n",
    "    \"nx\": 30,\n",
    "    \"ny\": 30,\n",
    "    \"nz\": 15,\n",
    "\n",
    "    # BHE setting: 3x3 = 9 根\n",
    "    \"n_bhe_x\": 3,\n",
    "    \"n_bhe_y\": 3,\n",
    "    \"bhe_top\": -2.0,\n",
    "    \"bhe_bottom\": -30.0,\n",
    "\n",
    "    # Heat source\n",
    "    \"heat_power_wm\": 120.0,   # W/m per BHE\n",
    "\n",
    "    # Flow forcing\n",
    "    \"p_diff\": 4000.0,         # Pa across 100 m\n",
    "\n",
    "    # Material / thermal parameters\n",
    "    \"T0\": 293.15,             # 20 °C in Kelvin\n",
    "    \"rho_f\": 1000.0,\n",
    "    \"mu_f\": 1.0e-3,\n",
    "    \"cp_f\": 4186.0,\n",
    "    \"lambda_f\": 0.6,\n",
    "\n",
    "    \"rho_s\": 2600.0,\n",
    "    \"cp_s\": 800.0,\n",
    "    \"lambda_s\": 2.5,\n",
    "\n",
    "    \"porosity\": 0.20,\n",
    "    \"permeability\": 5.0e-12,\n",
    "    \"alpha_L\": 1.0,\n",
    "    \"alpha_T\": 0.10,\n",
    "\n",
    "    # Time control: \n",
    "    \"t_end\": 10 * 86400,\n",
    "    \"dt\": 86400,\n",
    "    \"n_steps\": 10,\n",
    "\n",
    "    # Output\n",
    "    \"prefix\": \"HT_plume_debug_3x3_submesh\"\n",
    "}\n",
    "\n",
    "OUT_DIR = Path(\".\")\n",
    "BULK_MESH_FILE = OUT_DIR / \"model_mesh.vtu\"\n",
    "HEATER_MESH_FILE = OUT_DIR / \"heater_mesh.vtu\"\n",
    "GML_FILE = OUT_DIR / \"model_geo.gml\"\n",
    "PRJ_FILE = OUT_DIR / \"simulation_plume.prj\"\n"
   ]
