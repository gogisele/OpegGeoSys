    "# =========================================================\n",
    "# 4. Build PRJ\n",
    "# =========================================================\n",
    "def build_prj():\n",
    "    print(\"3. Building PRJ file...\")\n",
    "\n",
    "    dx = CFG[\"lx\"] / CFG[\"nx\"]\n",
    "    dy = CFG[\"ly\"] / CFG[\"ny\"]\n",
    "\n",
    "    # q''' = q' / A\n",
    "    vol_heat = CFG[\"heat_power_wm\"] / (dx * dy)\n",
    "\n",
    "    media_xml = f\"\"\"\n",
    "    <media>\n",
    "        <medium id=\"0\">\n",
    "            <phases>\n",
    "                <phase>\n",
    "                    <type>AqueousLiquid</type>\n",
    "                    <properties>\n",
    "                        <property>\n",
    "                            <name>viscosity</name>\n",
    "                            <type>Constant</type>\n",
    "                            <value>{CFG[\"mu_f\"]}</value>\n",
    "                        </property>\n",
    "                        <property>\n",
    "                            <name>density</name>\n",
    "                            <type>Constant</type>\n",
    "                            <value>{CFG[\"rho_f\"]}</value>\n",
    "                        </property>\n",
    "                        <property>\n",
    "                            <name>specific_heat_capacity</name>\n",
    "                            <type>Constant</type>\n",
    "                            <value>{CFG[\"cp_f\"]}</value>\n",
    "                        </property>\n",
    "                        <property>\n",
    "                            <name>thermal_conductivity</name>\n",
    "                            <type>Constant</type>\n",
    "                            <value>{CFG[\"lambda_f\"]}</value>\n",
    "                        </property>\n",
    "                    </properties>\n",
    "                </phase>\n",
    "\n",
    "                <phase>\n",
    "                    <type>Solid</type>\n",
    "                    <properties>\n",
    "                        <property>\n",
    "                            <name>density</name>\n",
    "                            <type>Constant</type>\n",
    "                            <value>{CFG[\"rho_s\"]}</value>\n",
    "                        </property>\n",
    "                        <property>\n",
    "                            <name>specific_heat_capacity</name>\n",
    "                            <type>Constant</type>\n",
    "                            <value>{CFG[\"cp_s\"]}</value>\n",
    "                        </property>\n",
    "                        <property>\n",
    "                            <name>thermal_conductivity</name>\n",
    "                            <type>Constant</type>\n",
    "                            <value>{CFG[\"lambda_s\"]}</value>\n",
    "                        </property>\n",
    "                        <property>\n",
    "                            <name>storage</name>\n",
    "                            <type>Constant</type>\n",
    "                            <value>0.0</value>\n",
    "                        </property>\n",
    "                    </properties>\n",
    "                </phase>\n",
    "            </phases>\n",
    "\n",
    "            <properties>\n",
    "                <property>\n",
    "                    <name>permeability</name>\n",
    "                    <type>Constant</type>\n",
    "                    <value>{CFG[\"permeability\"]}</value>\n",
    "                </property>\n",
    "                <property>\n",
    "                    <name>porosity</name>\n",
    "                    <type>Constant</type>\n",
    "                    <value>{CFG[\"porosity\"]}</value>\n",
    "                </property>\n",
    "                <property>\n",
    "                    <name>thermal_conductivity</name>\n",
    "                    <type>EffectiveThermalConductivityPorosityMixing</type>\n",
    "                </property>\n",
    "                <property>\n",
    "                    <name>thermal_longitudinal_dispersivity</name>\n",
    "                    <type>Constant</type>\n",
    "                    <value>{CFG[\"alpha_L\"]}</value>\n",
    "                </property>\n",
    "                <property>\n",
    "                    <name>thermal_transversal_dispersivity</name>\n",
    "                    <type>Constant</type>\n",
    "                    <value>{CFG[\"alpha_T\"]}</value>\n",
    "                </property>\n",
    "            </properties>\n",
    "        </medium>\n",
    "    </media>\n",
    "    \"\"\"\n",
    "\n",
    "    prj = f\"\"\"<?xml version=\"1.0\" encoding=\"ISO-8859-1\"?>\n",
    "<OpenGeoSysProject>\n",
    "    <meshes>\n",
    "        <mesh>{BULK_MESH_FILE.name}</mesh>\n",
    "        <mesh>{HEATER_MESH_FILE.name}</mesh>\n",
    "    </meshes>\n",
    "\n",
    "    <geometry>{GML_FILE.name}</geometry>\n",
    "\n",
    "    <processes>\n",
    "        <process>\n",
    "            <name>HT</name>\n",
    "            <type>HT</type>\n",
    "            <integration_order>2</integration_order>\n",
    "            <process_variables>\n",
    "                <pressure>p</pressure>\n",
    "                <temperature>T</temperature>\n",
    "            </process_variables>\n",
    "            <specific_body_force>0 0 -9.81</specific_body_force>\n",
    "            <secondary_variables>\n",
    "                <secondary_variable internal_name=\"darcy_velocity\" output_name=\"velocity\"/>\n",
    "            </secondary_variables>\n",
    "        </process>\n",
    "    </processes>\n",
    "\n",
    "    {media_xml}\n",
    "\n",
    "    <time_loop>\n",
    "        <processes>\n",
    "            <process ref=\"HT\">\n",
    "                <nonlinear_solver>basic_picard</nonlinear_solver>\n",
    "                <convergence_criterion>\n",
    "                    <type>PerComponentDeltaX</type>\n",
    "                    <norm_type>NORM2</norm_type>\n",
    "                    <reltols>1e-8 1e-8</reltols>\n",
    "                </convergence_criterion>\n",
    "                <time_discretization>\n",
    "                    <type>BackwardEuler</type>\n",
    "                </time_discretization>\n",
    "                <time_stepping>\n",
    "                    <type>FixedTimeStepping</type>\n",
    "                    <t_initial>0</t_initial>\n",
    "                    <t_end>{CFG[\"t_end\"]}</t_end>\n",
    "                    <timesteps>\n",
    "                        <pair>\n",
    "                            <repeat>{CFG[\"n_steps\"]}</repeat>\n",
    "                            <delta_t>{CFG[\"dt\"]}</delta_t>\n",
    "                        </pair>\n",
    "                    </timesteps>\n",
    "                </time_stepping>\n",
    "            </process>\n",
    "        </processes>\n",
    "\n",
    "        <output>\n",
    "            <type>VTK</type>\n",
    "            <prefix>{CFG[\"prefix\"]}</prefix>\n",
    "            <timesteps>\n",
    "                <pair>\n",
    "                    <repeat>1</repeat>\n",
    "                    <each_steps>1</each_steps>\n",
    "                </pair>\n",
    "            </timesteps>\n",
    "            <variables>\n",
    "                <variable>T</variable>\n",
    "                <variable>p</variable>\n",
    "                <variable>velocity</variable>\n",
    "            </variables>\n",
    "        </output>\n",
    "    </time_loop>\n",
    "\n",
    "    <parameters>\n",
    "        <parameter>\n",
    "            <name>T_ambient</name>\n",
    "            <type>Constant</type>\n",
    "            <value>{CFG[\"T0\"]}</value>\n",
    "        </parameter>\n",
    "\n",
    "        <parameter>\n",
    "            <name>heat_source</name>\n",
    "            <type>Constant</type>\n",
    "            <value>{vol_heat}</value>\n",
    "        </parameter>\n",
    "\n",
    "        <parameter>\n",
    "            <name>p_left</name>\n",
    "            <type>Function</type>\n",
    "            <expression>{101325.0 + CFG[\"p_diff\"]} - {CFG[\"rho_f\"]}*9.81*z</expression>\n",
    "        </parameter>\n",
    "\n",
    "        <parameter>\n",
    "            <name>p_right</name>\n",
    "            <type>Function</type>\n",
    "            <expression>{101325.0} - {CFG[\"rho_f\"]}*9.81*z</expression>\n",
    "        </parameter>\n",
    "\n",
    "        <parameter>\n",
    "            <name>p_init</name>\n",
    "            <type>Function</type>\n",
    "            <expression>{101325.0} - {CFG[\"rho_f\"]}*9.81*z</expression>\n",
    "        </parameter>\n",
    "    </parameters>\n",
    "\n",
    "    <process_variables>\n",
    "        <process_variable>\n",
    "            <name>T</name>\n",
    "            <components>1</components>\n",
    "            <order>1</order>\n",
    "            <initial_condition>T_ambient</initial_condition>\n",
    "\n",
    "            <boundary_conditions>\n",
    "                <boundary_condition>\n",
    "                    <geometrical_set>geo</geometrical_set>\n",
    "                    <geometry>top_face</geometry>\n",
    "                    <type>Dirichlet</type>\n",
    "                    <parameter>T_ambient</parameter>\n",
    "                </boundary_condition>\n",
    "            </boundary_conditions>\n",
    "\n",
    "            <source_terms>\n",
    "                <source_term>\n",
    "                    <mesh>{HEATER_MESH_FILE.stem}</mesh>\n",
    "                    <type>Volumetric</type>\n",
    "                    <parameter>heat_source</parameter>\n",
    "                </source_term>\n",
    "            </source_terms>\n",
    "        </process_variable>\n",
    "\n",
    "        <process_variable>\n",
    "            <name>p</name>\n",
    "            <components>1</components>\n",
    "            <order>1</order>\n",
    "            <initial_condition>p_init</initial_condition>\n",
    "\n",
    "            <boundary_conditions>\n",
    "                <boundary_condition>\n",
    "                    <geometrical_set>geo</geometrical_set>\n",
    "                    <geometry>left_face</geometry>\n",
    "                    <type>Dirichlet</type>\n",
    "                    <parameter>p_left</parameter>\n",
    "                </boundary_condition>\n",
    "\n",
    "                <boundary_condition>\n",
    "                    <geometrical_set>geo</geometrical_set>\n",
    "                    <geometry>right_face</geometry>\n",
    "                    <type>Dirichlet</type>\n",
    "                    <parameter>p_right</parameter>\n",
    "                </boundary_condition>\n",
    "            </boundary_conditions>\n",
    "        </process_variable>\n",
    "    </process_variables>\n",
    "\n",
    "    <nonlinear_solvers>\n",
    "        <nonlinear_solver>\n",
    "            <name>basic_picard</name>\n",
    "            <type>Picard</type>\n",
    "            <max_iter>100</max_iter>\n",
    "            <linear_solver>general_linear_solver</linear_solver>\n",
    "        </nonlinear_solver>\n",
    "    </nonlinear_solvers>\n",
    "\n",
    "    <linear_solvers>\n",
    "        <linear_solver>\n",
    "            <name>general_linear_solver</name>\n",
    "            <eigen>\n",
    "                <solver_type>BiCGSTAB</solver_type>\n",
    "                <precon_type>ILUT</precon_type>\n",
    "            </eigen>\n",
    "        </linear_solver>\n",
    "    </linear_solvers>\n",
    "</OpenGeoSysProject>\n",
    "\"\"\"\n",
    "    with open(PRJ_FILE, \"w\", encoding=\"utf-8\") as f:\n",
    "        f.write(prj)\n",
    "\n",
    "    print(f\"   -> {PRJ_FILE} written\")\n",
    "    print(f\"   -> volumetric heat source = {vol_heat:.6f} W/m^3\")\n",
    "\n",
    "\n"
