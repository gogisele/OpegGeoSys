    "# =========================================================\n",
    "# 1. Helpers\n",
    "# =========================================================\n",
    "def make_coords(length, n):\n",
    "    return np.linspace(-length / 2.0, length / 2.0, n + 1)\n",
    "\n",
    "def cell_centers_1d(arr):\n",
    "    return 0.5 * (arr[:-1] + arr[1:])\n",
    "\n",
    "def build_heater_indices(cx, cy):\n",
    "    \"\"\"\n",
    "    在 cell-center 座標上放 3x3 heaters\n",
    "    集中在中央附近，方便看 plume\n",
    "    \"\"\"\n",
    "    x_targets = np.linspace(-20.0, 20.0, CFG[\"n_bhe_x\"])\n",
    "    y_targets = np.linspace(-20.0, 20.0, CFG[\"n_bhe_y\"])\n",
    "\n",
    "    ix_list = [int(np.argmin(np.abs(cx - xt))) for xt in x_targets]\n",
    "    iy_list = [int(np.argmin(np.abs(cy - yt))) for yt in y_targets]\n",
    "\n",
    "    return sorted(set(ix_list)), sorted(set(iy_list))\n",
    "\n",
    "def node_id(i, j, k, ny, nz):\n",
    "    return i * (ny + 1) * (nz + 1) + j * (nz + 1) + k\n"
   ]
  },
